{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run vercel-build",
  "installCommand": "bun install",
  "env": {
    "DATABASE_URL": "file:./db/custom.db"
  },
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30,
      "includeFiles": "db/**"
    }
  }
}
