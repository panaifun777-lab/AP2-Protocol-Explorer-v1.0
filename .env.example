# AP2 Protocol Explorer — Environment Variables

# Database URL (SQLite for local dev, PostgreSQL for production/Vercel)
# Local SQLite:
DATABASE_URL="file:./db/custom.db"

# Production PostgreSQL (Vercel/Neon/Supabase) — uncomment and set for production:
# DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# NextAuth (optional, not used in current implementation)
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"
